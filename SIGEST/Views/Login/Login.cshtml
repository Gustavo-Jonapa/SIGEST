@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es-MX">
<head>
    <meta charset="utf-8">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar Sesión - SIGEST</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/Styles/StyleLogin.css" rel="stylesheet" />
    <link href="~/Styles/StyleRegistro.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <!-- Left Side - Branding -->
            <div class="branding-side">
                <div class="brand-logo">
                    <i class="bi bi-tools"></i>
                    <h1>SIGEST</h1>
                </div>
                <p class="brand-description">
                    Sistema Integral de Gestión y Asignación de Servicios Técnicos
                </p>
                <ul class="feature-list">
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Conecta con profesionales verificados</span>
                    </li>
                    <li>
                        <i class="bi bi-shield-check"></i>
                        <span>Servicios garantizados y seguros</span>
                    </li>
                    <li>
                        <i class="bi bi-star-fill"></i>
                        <span>Sistema de calificaciones confiable</span>
                    </li>
                </ul>
            </div>

            <!-- Right Side - Forms -->
            <div class="form-side">
                <div class="form-header">
                    <h2>Bienvenido</h2>
                    <p>Inicia sesión o crea una cuenta para continuar</p>
                </div>

                @* Mostrar mensaje de error si existe *@
                @if (TempData["Error"] != null)
                {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                }

                <!-- Tabs -->
                <div class="form-tabs">
                    <button class="form-tab active" onclick="switchTab('login')">
                        Iniciar Sesión
                    </button>
                    <button class="form-tab" onclick="switchTab('register')">
                        Registrarse
                    </button>
                </div>

                <!-- Login Form -->
                <div class="form-content active" id="login-form">
                    @using (Html.BeginForm("Login", "Login", FormMethod.Post, new { id = "loginForm", @class = "needs-validation", novalidate = "novalidate" }))
                    {
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label for="email">Usuario o Correo Electrónico</label>
                        <input type="text" class="form-control" id="email" name="email"
                               placeholder="admin" required autocomplete="on" />
                        <div class="invalid-feedback">
                            Por favor ingresa tu usuario o correo
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="password">Contraseña</label>
                        <div class="input-group">
                            <input type="password" class="form-control" id="password" name="password"
                                   placeholder="••••••••" required autocomplete="current-password" />
                            <i class="bi bi-eye input-icon" onclick="togglePassword('password', this)"></i>
                        </div>
                        <div class="invalid-feedback">
                            Por favor ingresa tu contraseña
                        </div>
                    </div>

                    <div class="forgot-password">
                        <a href="#" onclick="showForgotPassword(); return false;">¿Olvidaste tu contraseña?</a>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="rememberMe" name="rememberMe" value="true" />
                        <label class="form-check-label" for="rememberMe">
                            Recordar usuario
                        </label>
                    </div>

                    <button type="submit" class="btn-primary">
                        Iniciar sesión
                    </button>
                    }

                    <div class="form-footer">
                        ¿No tienes cuenta?
                        <a href="#" onclick="switchTab('register'); return false;">Regístrate aquí</a>
                    </div>

                    @* Credenciales de prueba *@
                    <div class="alert alert-info mt-3 small">
                        <strong>Credenciales de prueba:</strong><br />
                        Cliente: <code>cliente@ejemplo.com</code> / <code>12345678</code><br />
                        Técnico: <code>tecnico@ejemplo.com</code> / <code>12345678</code><br />
                        Admin: <code>admin</code> / <code>admin</code>
                    </div>
                </div>
                <!-- ------------------------------------------------------------------------------------------ -->
                <!-- Register Form -->
                    <div class="register-body">
                        <!-- Selector de Tipo de Cuenta -->
                        <div class="account-type-selector">
                            <div class="account-type-card" id="card-cliente" onclick="selectAccountType('cliente')">
                                <i class="bi bi-person-circle"></i>
                                <h5>Cliente</h5>
                                <input type="radio" name="accountType" value="cliente" id="radio-cliente">
                            </div>

                            <div class="account-type-card" id="card-tecnico" onclick="selectAccountType('tecnico')">
                                <i class="bi bi-tools"></i>
                                <h5>Técnico</h5>
                                <input type="radio" name="accountType" value="tecnico" id="radio-tecnico">
                            </div>
                        </div>

                        <!-- Formulario de Cliente -->
                        <form method="post" action="@Url.Action("Register", "Login")" id="form-cliente" style="display:none;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Role" value="cliente">

                            <div class="mb-3">
                                <label class="form-label">Nombre completo</label>
                                <input type="text" class="form-control" name="Name" placeholder="Juan Pérez" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Correo Electrónico</label>
                                <input type="email" class="form-control" name="Email" placeholder="correo@ejemplo.com" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Teléfono</label>
                                <input type="tel" class="form-control" name="Phone" placeholder="+52 961 123 4567" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Contraseña</label>
                                <input type="password" class="form-control" name="Password" placeholder="Mínimo 8 caracteres" minlength="8" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Confirmar Contraseña</label>
                                <input type="password" class="form-control" name="ConfirmPassword" placeholder="Repite tu contraseña" minlength="8" required>
                            </div>

                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="acceptTermsCliente" required>
                                <label class="form-check-label" for="acceptTermsCliente">
                                    Acepto los <a href="#" target="_blank">términos y condiciones</a>
                                </label>
                            </div>

                            <button type="submit" class="btn btn-primary">
                                Crear cuenta
                            </button>
                        </form>

                        <!-- Mensaje para Técnicos -->
                        <div id="tecnico-redirect" style="display:none;">
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-2"></i>
                                <strong>Registro de Técnico</strong><br>
                                El registro de técnicos requiere documentación adicional para verificación.
                            </div>
                            <button type="button" class="btn btn-primary" onclick="redirectToTecnicoRegister()">
                                Continuar al Registro de Técnico
                            </button>
                        </div>

                        <!-- Mensaje si no se seleccionó tipo -->
                        <div id="no-selection" class="text-center text-muted">
                            Selecciona el tipo de cuenta que deseas crear
                        </div>

                        <div class="back-to-login">
                            ¿Ya tienes cuenta? <a href="@Url.Action("Login", "Login")">Inicia sesión aquí</a>
                        </div>
                    </div>
                </div>
                <!-- ------------------------------------------------------------------------------------------ -->
            </div>
        </div>
    <script src="~/JS/ScriptRegistro.js"></script>
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        //Redirección a formulario Técnicos
        function redirectToTecnicoRegister() {
            window.location.href = '@Url.Action("RegistroTecnico", "Login")';
        }
        // Switch between login and register tabs
        function switchTab(tab) {
            const tabs = document.querySelectorAll('.form-tab');
            tabs.forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');

            const forms = document.querySelectorAll('.form-content');
            forms.forEach(f => f.classList.remove('active'));

            if (tab === 'login') {
                document.getElementById('login-form').classList.add('active');
            } else {
                document.getElementById('register-form').classList.add('active');
            }
        }

        // Toggle password visibility
        function togglePassword(inputId, icon) {
            const input = document.getElementById(inputId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }

        // Role card selection
        document.querySelectorAll('.role-card').forEach(card => {
            card.addEventListener('click', function() {
                document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
                this.classList.add('selected');
                this.querySelector('input[type="radio"]').checked = true;
            });
        });

        // Handle register form submission
        function handleRegister(e) {
            e.preventDefault();

            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData);

            // Validar contraseñas
            if (data.Password !== data.ConfirmPassword) {
                alert('Las contraseñas no coinciden');
                return;
            }

            if (!data.AcceptTerms) {
                alert('Debes aceptar los términos y condiciones');
                return;
            }

            const btn = e.target.querySelector('.btn-primary');
            btn.classList.add('btn-loading');
            btn.textContent = 'Creando cuenta...';

            // Enviar datos al servidor
            fetch('@Url.Action("Register", "Login")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(result => {
                if (result.success) {
                    window.location.href = result.redirectUrl;
                } else {
                    alert(result.message);
                    btn.classList.remove('btn-loading');
                    btn.textContent = 'Crear cuenta';
                }
            })
            .catch(error => {
                alert('Error al crear la cuenta');
                console.error('Error:', error);
                btn.classList.remove('btn-loading');
                btn.textContent = 'Crear cuenta';
            });
        }

        // Show forgot password dialog
        function showForgotPassword() {
            const email = prompt('Ingresa tu correo electrónico para recuperar tu contraseña:');
            if (email) {
                fetch('@Url.Action("ForgotPassword", "Login")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ email: email })
                })
                .then(response => response.json())
                .then(result => {
                    alert(result.message);
                })
                .catch(error => {
                    alert('Error al procesar la solicitud');
                    console.error('Error:', error);
                });
            }
        }

        // Form validation on submit
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            const btn = this.querySelector('.btn-primary');
            btn.classList.add('btn-loading');
            btn.textContent = 'Iniciando sesión...';
        });
    </script>
</body>
</html>
